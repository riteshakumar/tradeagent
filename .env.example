ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
PAPER_TRADING=true
CONFIRM_LIVE_TRADING=false

# Agent routing: openai | claude | none
USE_AGENT=true
AGENT_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# Execution mode
DRY_RUN=true
SHADOW_MODE=false
ALLOW_SHORT=false

# Core strategy
WATCHLIST=AAPL,MSFT,NVDA,TSLA
SIGNAL_THRESHOLD=3
BAR_TIMEFRAME=5Min
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_POSITION_PCT=0.10
RISK_PER_TRADE_PCT=0.01
MAX_DRAWDOWN_PCT=0.10
DAILY_LOSS_STOP_PCT=0.03
ORDER_COOLDOWN_SEC=300

# Portfolio caps
MAX_SECTOR_EXPOSURE_PCT=0.35
ENABLE_CORRELATION_CAP=true
MAX_CORRELATION=0.85
MAX_CORRELATED_POSITIONS=2
CORRELATION_LOOKBACK_DAYS=90
# Optional JSON override map:
# SYMBOL_SECTORS={"AAPL":"technology","MSFT":"technology","JPM":"financials"}

# Regime switching
ENABLE_REGIME_SWITCHING=true
HIGH_VOL_THRESHOLD=0.025
TREND_STRENGTH_THRESHOLD=0.012

# Screener filters
MIN_STOCK_PRICE=5.0
MIN_STOCK_VOLUME=500000

# Loop
LOOP_INTERVAL_SEC=300
AGENT_CACHE_TTL_SEC=300

# Backtest realism
BACKTEST_SLIPPAGE_BPS=2.0
BACKTEST_FEE_PER_TRADE=0.0

# Alerts
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=465
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_SLACK_WEBHOOK=
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
